{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permissions for the floating bubble window: resize on expand/collapse and drag-to-move.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-set-size",
    "core:window:allow-start-dragging",
    "core:window:allow-set-focus",
    "core:window:allow-set-always-on-top",
    "core:window:allow-show",
    "core:window:allow-hide",
    "allow-app-version",
    "allow-run-adapter",
    "allow-cancel-adapter-run",
    "allow-create-session",
    "allow-append-message",
    "allow-read-history",
    "allow-list-sessions",
    "allow-rename-session",
    "allow-delete-session",
    "allow-clear-session",
    "allow-update-codex-session-id",
    "allow-open-external"
  ]
}
