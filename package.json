{
  "name": "side-pilot",
  "version": "0.1.0",
  "description": "Cross-platform floating multi-AI desktop assistant (Tauri + React + TypeScript).",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier eslint.config.js package.json tsconfig.json tsconfig.node.json vite.config.ts playwright.config.ts vitest.setup.ts README.md \"src/**/*.{ts,tsx,css}\" \"e2e/**/*.ts\" .github/workflows/ci.yml --write",
    "format:check": "prettier eslint.config.js package.json tsconfig.json tsconfig.node.json vite.config.ts playwright.config.ts vitest.setup.ts README.md \"src/**/*.{ts,tsx,css}\" \"e2e/**/*.ts\" .github/workflows/ci.yml --check",
    "test": "vitest run",
    "test:smoke": "vitest run -t \"[smoke]\"",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:a11y": "vitest run src/**/*.a11y.* && playwright test e2e/a11y.spec.ts",
    "rust:test": "cargo nextest run --manifest-path src-tauri/Cargo.toml",
    "rust:clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings",
    "rust:audit": "cargo audit",
    "audit": "npm audit --production --audit-level=high",
    "test:mutation:ts": "stryker run",
    "test:mutation:rust": "cargo mutants --manifest-path src-tauri/Cargo.toml",
    "gen:bindings": "cargo test --manifest-path src-tauri/Cargo.toml export_bindings",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.19.19",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@axe-core/playwright": "^4.10.0",
    "jest-axe": "^9.0.0",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-testing-library": "^7.1.1",
    "fast-check": "^3.23.2",
    "jsdom": "^25.0.1",
    "prettier": "^3.8.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^6.0.3",
    "vitest": "^2.1.8",
    "@vitest/coverage-v8": "^2.1.8",
    "@stryker-mutator/core": "^8.7.1",
    "@stryker-mutator/vitest-runner": "^8.7.1"
  }
}
